#!/bin/bash
# Hand failure evidence to a guardrailed agent in ITS OWN clone.
set -uo pipefail
CONFIG="${PLUMB_CONFIG:-$(dirname "$0")/../plumb.config}"
# shellcheck source=/dev/null
source "$CONFIG"
CONTEXT_NAME="${1:?usage: plumb-escalate <name> <log-file>}"
LOG_PATH="${2:?usage: plumb-escalate <name> <log-file>}"
ESC_LOG="${LOG_FILE%.log}-escalations.log"

# Escalation is expensive (it spawns a headless agent run). Without limits, a
# check that fails every few minutes — or many per-context jobs failing at once
# — would spawn an unbounded stream of them. Three cheap guards, checked BEFORE
# any work: a per-context cooldown (dedup a flapping failure), a global daily
# cap (backstop across all contexts), and a per-context lock (never stack
# concurrent runs of the same failure). Tunable via the config / environment.
STATE_DIR="${PLUMB_STATE_DIR:-$(dirname "$LOG_FILE")/state}"; mkdir -p "$STATE_DIR"
COOLDOWN_SECS=${PLUMB_ESCALATE_COOLDOWN_SECS:-21600}   # 6h: same failure won't re-escalate
DAILY_CAP=${PLUMB_ESCALATE_DAILY_CAP:-8}               # max escalations/day, all contexts
NOW=$(date +%s)
SLUG=$(printf '%s' "$CONTEXT_NAME" | tr -c 'A-Za-z0-9' '_')
suppress() { echo "$(date -Is) SUPPRESS $CONTEXT_NAME ($1)" >> "$ESC_LOG"; exit 0; }

# Per-context lock — if a run for this context is already in flight, skip. Only
# when flock exists; if it's somehow missing, fall through to cooldown+cap
# rather than suppressing every escalation (silent-suppress would be worse).
if command -v flock >/dev/null 2>&1; then
  exec 9>"$STATE_DIR/lock-$SLUG"
  flock -n 9 || suppress "already running"
fi

# Per-context cooldown.
STAMP="$STATE_DIR/last-$SLUG"
if [ -f "$STAMP" ]; then
  LAST=$(cat "$STAMP" 2>/dev/null || echo 0)
  [ $(( NOW - LAST )) -lt "$COOLDOWN_SECS" ] && suppress "within ${COOLDOWN_SECS}s cooldown"
fi

# Global daily cap.
COUNTFILE="$STATE_DIR/count-$(date +%Y%m%d)"
COUNT=$(cat "$COUNTFILE" 2>/dev/null || echo 0)
[ "$COUNT" -ge "$DAILY_CAP" ] && suppress "daily cap $DAILY_CAP reached"

# Passed the guards — record the attempt, prune stale day counters, then proceed.
echo "$NOW" > "$STAMP"
echo $(( COUNT + 1 )) > "$COUNTFILE"
find "$STATE_DIR" -name 'count-*' -mtime +3 -delete 2>/dev/null || true

EVIDENCE=$(tail -c 4000 "$LOG_PATH" 2>/dev/null || echo "log unavailable")

# The agent never works in the deploy checkout: a wrong move cannot leak into
# a production build. Full tool permissions are safe inside this boundary.
if [ ! -d "$AGENT_WORKDIR/.git" ]; then
  mkdir -p "$(dirname "$AGENT_WORKDIR")" && git clone -q "$REPO_URL" "$AGENT_WORKDIR"
fi
git -C "$AGENT_WORKDIR" fetch -q origin && git -C "$AGENT_WORKDIR" reset -q --hard origin/main

bash -lc "cd '$AGENT_WORKDIR' && $AGENT_CMD 'You are the on-call maintenance agent for this deployment.

An automated check or job named \"$CONTEXT_NAME\" failed. Evidence (log tail):
---
$EVIDENCE
---

Diagnose the root cause. Read ${CONTEXT_DOCS:-the repo docs} first. You may inspect services, containers, and logs, and run READ-ONLY queries against databases.

STRICT GUARDRAILS:
- Never modify or delete production data; SELECT-only against any database.
- Never commit to main, never force-push, never touch secrets files.
- Confident code/config fix: branch auto/fix-<short-name>, commit, push the branch, open a PR (gh pr create) describing cause and fix. Do NOT merge.
- Uncertain or environmental cause (disk, network, upstream outage): file an issue titled \"[auto] $CONTEXT_NAME failing\" with full diagnosis and recommendation — check for an existing open issue with that title first and comment instead of duplicating.
- End with a one-paragraph summary of what you did.'" >> "$ESC_LOG" 2>&1
